{
  "name": "landlordbuddy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:spine": "node --experimental-strip-types check.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
